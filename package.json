{
  "name": "playwright-auto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web:wait\"",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:web:wait": "tsx scripts/wait-for-server.ts && npm run dev:web",
    "dev:server": "tsx server/src/index.ts",
    "dev:server:watch": "tsx watch server/src/index.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "npm run typecheck && npm run build:web",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "postinstall": "node scripts/install-browsers.mjs"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "element-plus": "^2.8.8",
    "express": "^4.19.2",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.10",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
