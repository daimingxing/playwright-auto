{
  "server": {
    "port": 3001,
    "dataRoot": "data",
    "corsOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "web": {
    "origin": "http://localhost:5173",
    "apiBase": ""
  },
  "runner": {
    "headlessWorkers": 4,
    "headedWorkers": 1,
    "maxWorkers": 20
  },
  "steps": {
    "timeouts": {
      "navigation": 20000,
      "action": 2000,
      "wait": 1000
    }
  },
  "ai": {
    "enabled": true,
    "baseUrl": "https://api.deepseek.com",
    "apiKey": "",
    "model": "deepseek-v4-flash",
    "temperature": 0.1,
    "timeoutMs": 60000,
    "maxRetries": 1,
    "concurrency": 1
  }
}