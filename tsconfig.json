{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@server/*": ["server/src/*"],
      "@web/*": ["web/src/*"]
    }
  },
  "include": ["server/src", "shared", "web/src", "tests", "vitest.config.ts", "web/vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
